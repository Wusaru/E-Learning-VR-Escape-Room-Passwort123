  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Man-in-the-Middle (MITM) Angriff\r\n\r\nBei einem Man-in-the-Middle Angriff
    Schaltet sich ein Angreifer zwischen 2 Kommunikationspartener (hier Nutzer und
    Server) und h\xF6rt Sie ab oder manipuliert anfragen.\r\n\r\nH\xE4ufig t\xE4uscht
    der Angreifer dabei beide Seiten, indem er vrogibt der Kommunikationspartner
    zu sein.\r\n\r\nIn dieser Simulation:\r\n\u2022 Gr\xFCne Kugeln sind Datenpakete
    des Nutzers, die nicht manipuliert wurden\r\n\u2022 Rote Kugeln sind Datenpakete,
    die der Angreifer erstellt oder manipuliert hat\r\n\u2022 Der Angreifer steht
    zwischen dem Nutzer und den Server\r\n\u2022 Zuerst wird gezeigt, wie der Angreifer
    eine Nachricht abf\xE4ngt, eine Kopie speichert und an den Server weiterleitet\r\n\u2022
    Anschlie\xDFend wird gezeigt, wie eine Nachricht abgefangen und manipuliert weitergeleitet
    wird\r\n\u2022 Zum Schluss wird gezeigt, wie der Angreifer die gespeicherte Kopie
    verwendet"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
