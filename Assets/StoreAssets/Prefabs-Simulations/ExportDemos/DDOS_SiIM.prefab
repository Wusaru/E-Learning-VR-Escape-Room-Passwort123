  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9541d86e2fd84c1d9990edf0852d74ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshPro
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "What is a DDoS attack?\n\nA Distributed Denial of Service (DDoS) attack
    floods a server\nwith a massive number of requests from many devices at once.\n\nIn
    this simulation:\n\n\u2022 Green packets represent legitimate users.\n\u2022
    Red packets represent malicious traffic.\n\u2022 The server processes requests
    normally at first.\n\u2022 As attack traffic increases, the server becomes overloaded.\n\u2022
    Legitimate users can no longer reach the server and must wait in a queue.\n\nThis
    demonstrates how a DDoS attack can make a service\nslow or completely unavailable."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
